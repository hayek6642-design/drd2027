#### **2. cloudinary-api.js**
```javascript
// Key function with pagination
async function getAllTracks(nextCursor = null, folderPrefix = 'media-player/') {
    const options = {
        resource_type: 'video',
        type: 'upload',
        prefix: folderPrefix,
        max_results: 500,  // High limit for efficiency
        ...(nextCursor && { next_cursor: nextCursor })
    };

    try {
        const result = await cloudinary.api.resources(options);
        const tracks = result.resources || [];
        
        if (result.next_cursor) {
            const moreTracks = await getAllTracks(result.next_cursor, folderPrefix);
            return tracks.concat(moreTracks);
        } else {
            return tracks;
        }
    } catch (error) {
        console.error("Error fetching tracks from Cloudinary:", error);
        return [];
    }
}
```

