{
    "name": "yt-clear",
    "version": "1.0.0",
    "description": "Independent CodeBank & Games-Centre Server",
    "main": "server.js",
    "type": "module",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "start:3001": "PORT=3001 node server.js",
        "dev:3001": "PORT=3001 node --watch server.js",
        "pm2:start": "pm2 start server.js --name yt-clear --time --log-date-format 'YYYY-MM-DD HH:mm:ss' --max-memory-restart 500M",
        "pm2:start:3001": "pm2 start server.js --name yt-clear-3001 --time --log-date-format 'YYYY-MM-DD HH:mm:ss' --max-memory-restart 500M -- --port 3001",
        "pm2:stop": "pm2 stop yt-clear",
        "pm2:stop:3001": "pm2 stop yt-clear-3001",
        "pm2:restart": "pm2 restart yt-clear",
        "pm2:restart:3001": "pm2 restart yt-clear-3001",
        "pm2:delete": "pm2 delete yt-clear",
        "pm2:delete:3001": "pm2 delete yt-clear-3001",
        "pm2:logs": "pm2 logs yt-clear --lines 100",
        "pm2:logs:3001": "pm2 logs yt-clear-3001 --lines 100",
        "pm2:monitor": "pm2 monit",
        "pm2:status": "pm2 status",
        "build": "vite build",
        "preview": "vite preview",
        "test": "echo \"No tests specified\" && exit 0"
    },
    "dependencies": {
        "@libsql/client": "^0.17.2",
        "axios": "^1.13.6",
        "bcryptjs": "^3.0.3",
        "better-sqlite3": "^11.6.0",
        "cloudinary": "^1.41.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "countries-list": "^3.3.0",
        "dotenv": "^16.3.1",
        "express": "^4.19.0",
        "express-rate-limit": "^7.1.5",
        "firebase-admin": "^13.7.0",
        "fs-extra": "^11.2.0",
        "gsap": "^3.14.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "libphonenumber-js": "^1.12.40",
        "matter-js": "^0.20.0",
        "multer": "^1.4.5-lts.1",
        "node-fetch": "^2.7.0",
        "nodemailer": "^8.0.3",
        "pg": "^8.16.3",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "three": "^0.183.1",
        "twilio": "^5.12.2",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "pm2": "^6.0.14",
        "vite": "^8.0.0"
    }
}
