{
    "name": "yt-clear",
    "version": "1.1.0",
    "description": "Independent CodeBank & Games-Centre Server",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "node --watch server.js",
        "start:3001": "PORT=3001 node server.js",
        "dev:3001": "PORT=3001 node --watch server.js",
        "pm2:start": "pm2 start server.js --name yt-clear --time --log-date-format 'YYYY-MM-DD HH:mm:ss' --max-memory-restart 500M",
        "pm2:start:3001": "pm2 start server.js --name yt-clear-3001 --time --log-date-format 'YYYY-MM-DD HH:mm:ss' --max-memory-restart 500M -- --port 3001",
        "pm2:stop": "pm2 stop yt-clear",
        "pm2:stop:3001": "pm2 stop yt-clear-3001",
        "pm2:restart": "pm2 restart yt-clear",
        "pm2:restart:3001": "pm2 restart yt-clear-3001",
        "pm2:delete": "pm2 delete yt-clear",
        "pm2:delete:3001": "pm2 delete yt-clear-3001",
        "pm2:logs": "pm2 logs yt-clear --lines 100",
        "pm2:logs:3001": "pm2 logs yt-clear-3001 --lines 100",
        "pm2:monitor": "pm2 monit",
        "pm2:status": "pm2 status",
        "build": "vite build",
        "preview": "vite preview",
        "test": "echo \"No tests specified\" && exit 0",
        "mobile:prepare": "node build-apk.js --prepare-only",
        "mobile:build": "node build-apk.js --android",
        "mobile:build:ios": "node build-apk.js --ios",
        "mobile:build:all": "node build-apk.js",
        "mobile:build:release": "node build-apk.js --android --release",
        "mobile:sync": "npx cap sync",
        "mobile:open:android": "npx cap open android",
        "mobile:open:ios": "npx cap open ios",
        "mobile:run:android": "npx cap run android",
        "mobile:run:ios": "npx cap run ios"
    },
    "dependencies": {
        "@capacitor-community/contacts": "^6.0.0",
        "@capacitor/app": "^6.0.0",
        "@capacitor/app-launcher": "^6.0.0",
        "@capacitor/camera": "^6.0.0",
        "@capacitor/clipboard": "^6.0.0",
        "@capacitor/core": "^6.2.0",
        "@capacitor/device": "^6.0.0",
        "@capacitor/haptics": "^6.0.0",
        "@capacitor/keyboard": "^6.0.0",
        "@capacitor/local-notifications": "^6.0.0",
        "@capacitor/network": "^6.0.0",
        "@capacitor/preferences": "^6.0.0",
        "@capacitor/push-notifications": "^6.0.0",
        "@capacitor/share": "^6.0.0",
        "@capacitor/splash-screen": "^6.0.0",
        "@capacitor/status-bar": "^6.0.0",
        "@libsql/client": "^0.17.2",
        "@simplewebauthn/server": "^10.0.0",
        "axios": "^1.13.6",
        "bcryptjs": "^3.0.3",
        "cloudinary": "^1.41.0",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "countries-list": "^3.3.0",
        "dotenv": "^16.3.1",
        "express": "^4.19.0",
        "express-rate-limit": "^7.1.5",
        "firebase-admin": "^13.7.0",
        "fs-extra": "^11.2.0",
        "gsap": "^3.14.2",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "libphonenumber-js": "^1.12.40",
        "matter-js": "^0.20.0",
        "multer": "^1.4.5-lts.1",
        "node-fetch": "^2.7.0",
        "nodemailer": "^8.0.3",
        "pg": "^8.16.3",
        "socket.io": "^4.8.3",
        "socket.io-client": "^4.8.3",
        "three": "^0.183.1",
        "twilio": "^5.12.2",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@capacitor/android": "^6.2.0",
        "@capacitor/cli": "^6.2.0",
        "@capacitor/ios": "^6.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "pm2": "^6.0.14",
        "terser": "^5.46.1",
        "vite": "^8.0.0"
    },
    "optionalDependencies": {
        "better-sqlite3": "^11.6.0",
        "capacitor-native-biometric": "^4.2.2"
    }
}
